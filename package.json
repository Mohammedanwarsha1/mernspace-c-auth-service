    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/bcrypt": "^6.0.0",
        "@types/dotenv": "^6.1.1",
        "@types/eslint__js": "^8.42.3",
        "@types/express": "^5.0.6",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.6.0",
        "@types/supertest": "^7.2.0",
        "@types/winston": "^2.4.4",
        "eslint": "^9.39.4",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.14",
        "prettier": "3.8.2",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.2"
