{
    "name": "auth-service",
    "version": "1.0.0",
    "type": "module",
    "description": "The user management service",
    "main": "index.js",
    "scripts": {
        "dev": "nodemon --watch src --ext ts,json --exec tsx src/server.ts",
        "format:fix": "prettier . --write",
        "format:check": "prettier . --check",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "echo \"Error: no test specified\" && exit 1",
        "prepare": "husky"
    },
    "author": "Anwar shah <mohammedanwarsha2019@gmail.com>",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/dotenv": "^6.1.1",
        "@types/eslint__js": "^8.42.3",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "@types/winston": "^2.4.4",
        "eslint": "^9.39.4",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.14",
        "prettier": "3.8.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.2"
    },
    "lint-staged": {
        "*.ts": [
            "npm run format:fix",
            "npm run lint:fix"
        ]
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "winston": "^3.19.0"
    }
